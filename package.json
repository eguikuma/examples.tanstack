{
  "name": "examples.tanstack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "lint": "biome lint ./sources",
    "lint:fix": "biome lint --fix ./sources",
    "format": "biome format ./sources",
    "format:fix": "biome format --write ./sources",
    "tsc": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "ci": "run-p lint:fix format:fix tsc test:run",
    "package:deps": "ncu",
    "package:update": "ncu -i",
    "package:update:force": "ncu -u"
  },
  "dependencies": {
    "@tanstack/query-core": "^5.90.8",
    "@tanstack/react-query": "^5.90.8",
    "http-status-codes": "^2.3.0",
    "react": "^19.2.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@vitest/ui": "^4.0.8",
    "happy-dom": "^20.0.10",
    "npm-check-updates": "^19.1.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
